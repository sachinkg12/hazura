{
  "name": "@myhazardprofile/core",
  "version": "0.1.0",
  "description": "Multi-hazard personal risk assessment engine using federal open data (FEMA, USGS, NOAA)",
  "keywords": [
    "hazard",
    "risk",
    "fema",
    "earthquake",
    "wildfire",
    "hurricane",
    "tornado",
    "flood",
    "disaster",
    "preparedness",
    "geospatial"
  ],
  "license": "Apache-2.0",
  "author": "MyHazardProfile Contributors",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.0"
  }
}
