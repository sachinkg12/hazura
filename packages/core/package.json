{
  "name": "@hazardprep/core",
  "version": "0.1.0",
  "description": "Multi-hazard personal risk assessment engine using federal open data (FEMA, USGS, NOAA)",
  "keywords": [
    "hazard",
    "risk",
    "fema",
    "earthquake",
    "wildfire",
    "hurricane",
    "tornado",
    "flood",
    "disaster",
    "preparedness",
    "geospatial",
    "emergency",
    "natural-disaster",
    "risk-assessment"
  ],
  "license": "Apache-2.0",
  "author": "Sachin Gupta <sachinkg12@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/sachinkg12/hazardprep.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/sachinkg12/hazardprep#readme",
  "bugs": {
    "url": "https://github.com/sachinkg12/hazardprep/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "typescript": "^5.4.0"
  }
}
